{
  "name": "@irithell-js/uno",
  "version": "1.0.1-json",
  "description": "Complete UNO card game engine with AI players",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run build:code && npm run build:assets",
    "build:code": "tsup",
    "build:assets": "cp -r assets dist/",
    "dev": "tsup --watch",
    "test": "jest",
    "prepublishOnly": "npm run build",
    "pack:check": "npm pack --silent && node -e \"console.log('packed')\""
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "uno",
    "card-game",
    "game-engine",
    "ai",
    "game",
    "multiplayer",
    "typescript",
    "uno-game",
    "card-game-engine"
  ],
  "author": "Irithell",
  "engines": {
    "node": ">=18.0.0"
  }
}
